---
import { Image } from "astro:assets"
import Layout from "../layouts/Layout.astro"
import { appStoreUrl, googlePlayUrl } from "../utils/links"
---

<Layout>
    <main class="relative md:h-screen">
        <div class="flex h-full flex-col items-center justify-center p-12">
            <div
                class="flex flex-col items-center justify-center gap-6 text-center lg:flex-row lg:gap-12 lg:text-left"
            >
                <div
                    id="transito-logo"
                    class="group mb-4 grid size-80 cursor-pointer drop-shadow-2xl drop-shadow-[#8E85FF]/60 transition-all select-none hover:drop-shadow-[#8E85FF]/30 data-[qr-locked=true]:drop-shadow-[#8E85FF]/30 *:transition-opacity *:duration-200 *:ease-in md:size-96 lg:mb-0 lg:size-104"
                    role="button"
                    tabindex="0"
                    aria-label="Show Transito QR code"
                    aria-pressed="false"
                >
                    <Image
                        class={"col-start-1 row-start-1"}
                        src={"/images/qr-code.svg"}
                        alt={"Transito's App Icon"}
                        width={512}
                        height={512}
                        loading="lazy"
                    />
                    <Image
                        data-logo
                        class={"group-hover:opacity-0 group-data-[qr-locked=true]:opacity-0 opacity-100 col-start-1 row-start-1"}
                        src={"/images/transito-icon.svg"}
                        alt={"Transito's App Icon"}
                        width={512}
                        height={512}
                        loading="eager"
                    />
                </div>
                <div class="max-w-[56ch] p-4 text-pretty">
                    <div>
                        <h1 class="ml-[-0.25ch] text-6xl font-extrabold">
                            Transito
                        </h1>
                        <h3 class="pt-1 text-xl font-semibold">
                            The last bus timing app you'll ever need
                        </h3>
                    </div>
                    <br />
                    <div class="font-sans text-lg">
                        <p>
                            Transito is the go-to app for bus timings. It's all
                            about giving you the info you need, fast. We
                            cherry-picked the best features to keep to keep
                            things straightforward, <em>no extra fluff</em>.
                        </p>
                        <br />
                        <p>
                            So, whether you're racing against the clock or just
                            taking it easy, Transito's got your back. Get on
                            board with Transito and catch your bus right on
                            time! 🚌 ⏰
                        </p>
                    </div>
                    <div
                        class="mt-8 flex flex-col items-center justify-center gap-6 sm:flex-row lg:mt-12 lg:justify-start"
                    >
                        <a href={appStoreUrl}>
                            <Image
                                src="/store-badges/App-Store.svg"
                                alt="Download on the App Store"
                                width="200"
                                height="40"
                                loading="eager"
                            />
                        </a>
                        <a href={googlePlayUrl}>
                            <Image
                                src="/store-badges/Google-Play.svg"
                                alt="Get it on Google Play"
                                width="216"
                                height="40"
                                loading="eager"
                            />
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <footer class="absolute bottom-0 w-full pb-3 text-center lg:pb-4">
            <a href="https://tnitish.com">
                <h5
                    class="group text-xl font-semibold text-[#25184e] opacity-65 transition duration-300 hover:opacity-80 lg:text-2xl lg:opacity-45"
                >
                    built by nitish.
                </h5>
            </a>
        </footer>
    </main>

    <script>
        const logoArea = document.querySelector<HTMLElement>("#transito-logo")

        const showQR = () => {
            const isQRLocked =
                logoArea?.getAttribute("data-qr-locked") === "true"

            if (isQRLocked) {
                logoArea?.setAttribute("data-qr-locked", "false")
                logoArea?.setAttribute("aria-pressed", "false")
            } else {
                logoArea?.setAttribute("data-qr-locked", "true")
                logoArea?.setAttribute("aria-pressed", "true")
            }
        }

        logoArea?.addEventListener("click", showQR)
        logoArea?.addEventListener("keydown", event => {
            if (event.key !== "Enter" && event.key !== " ") return
            event.preventDefault()
            showQR()
        })
    </script>
</Layout>
